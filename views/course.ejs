<!DOCTYPE html>
<html>
<head>
<title>Courses</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>

body{
margin:0;
font-family:Arial;
color:white;
background:
linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)),
url("page 3.jpg") no-repeat center center fixed;
background-size:cover;
}

header{
display:flex;
justify-content:space-between;
align-items:center;
padding:20px 40px;
background:rgba(0,0,0,0.6);
backdrop-filter:blur(10px);
}

header h1{
margin:0;
}

.back{
background:#007bff;
border:none;
padding:10px 20px;
border-radius:8px;
color:white;
cursor:pointer;
}

.container{
padding:40px;
}

.title{
font-size:32px;
margin-bottom:30px;
}

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:25px;
}

.course-card{
background:rgba(255,255,255,0.1);
padding:30px;
border-radius:20px;
text-align:center;
backdrop-filter:blur(10px);
transition:0.3s;
}

.course-card:hover{
background:rgba(255,255,255,0.2);
transform:translateY(-5px);
}

.course-card h2{
margin-bottom:10px;
}

.course-card p{
font-size:14px;
margin-bottom:15px;
}

.course-card button{
padding:10px 20px;
border:none;
border-radius:8px;
background:#28a745;
color:white;
cursor:pointer;
}

footer{
text-align:center;
padding:20px;
margin-top:40px;
background:rgba(0,0,0,0.6);
}

</style>
</head>

<body>

<header>

<h1>AI Courses</h1>

<button class="back" onclick="goDashboard()">Back</button>

</header>


<div class="container">

<div class="title">Start Learning 🚀</div>

<div class="grid">

<div class="course-card">
<h2>Java with OOPs</h2>
<p>Learn Java and build Java projects.</p>
<button onclick="openCourse('java')">Start</button>
</div>

</div>

</div>


<footer>
Career Navigator Learning Platform
</footer>


<script>

function goDashboard(){
window.location="/dashboard";
}

function openCourse(course){

if(course==="java"){
window.location="/course/java";
}

}

</script>

</body>
</html>
